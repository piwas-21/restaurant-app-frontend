# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.vscode/

# Archived files (old manual kubectl deployments)
.archived/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Bare .env is excluded — never commit local credentials. See CLAUDE.md §9.
.env

# Keep these files in git
!.env.example
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright E2E outputs (do NOT gitignore the whole e2e/ — tests are committed)
e2e/.auth/
test-results/
playwright-report/
.playwright-mcp/

# Claude Code per-repo settings (machine-local) — EXCEPT versioned subagents.
.claude/*
!.claude/agents/
