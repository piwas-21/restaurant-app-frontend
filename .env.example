# Environment Variables Template
# Copy this file to .env.local for local development.
# scripts/dev-secrets.sh does this for you on first setup.
#
# .env.local is gitignored. NEVER commit credentials.

# ── Application environment ──────────────────────────────────────────
# Used by build-time / runtime checks. Common values: development, preview, production.
NEXT_PUBLIC_APP_ENV=development

# ── Backend API URL (base URL only, without /api suffix) ─────────────
# Local development: http://localhost:5221 (or your backend port)
# Production: https://rumirestaurant.ch (Ingress will route /api to backend)
# Note: Your API routes should include /api prefix (e.g., /api/Products)
NEXT_PUBLIC_API_URL=http://localhost:5221

# ── Image / asset base URL ───────────────────────────────────────────
NEXT_PUBLIC_IMAGE_BASE_URL=https://rumi-test-backend-bucket.s3.eu-central-1.amazonaws.com

# ── Test-account credentials (Playwright E2E + manual local sign-in) ──
# These were previously committed in `.env`. They are now per-developer:
# fill in your own dev/test credentials here in your local `.env.local`.
# Format: JSON-ish single-quoted string with email + password fields.
# Examples (NOT real credentials — replace with your own dev/test values):
#   ADMIN='{email: admin@example.local, password: change-me}'
#   CASHIER='{email: cashier@example.local, password: change-me}'
#   CUSTOMER='{email: customer@example.local, password: change-me}'
ADMIN=
CASHIER=
CUSTOMER=
