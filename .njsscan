---
# njsscan configuration — paths to skip during the SAST pass.
#
# `qodana.sarif.json` is the Qodana baseline; it embeds password-URL
# substrings as part of the snippet text describing pre-existing
# findings (the e2e/helpers/db.ts Error-message hint and the
# scripts/dev-e2e.sh dev-compose comment). Without this exclusion,
# njsscan re-discovers those substrings every PR and fails the SAST
# check on the same false positives that gitleaks, detect-secrets,
# and Qodana already path-scope around. The actual source files
# stay in scope; only the generated baseline file is skipped.
ignore-filenames:
  - qodana.sarif.json
