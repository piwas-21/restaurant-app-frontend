# Production Environment Variables
# These values are used when deployed to Kubernetes

# Backend API URL - Production (without /api suffix since routes already include it)
# Using www subdomain to avoid CORS issues (same origin as frontend)
NEXT_PUBLIC_API_URL=https://www.rumirestaurant.ch

# Image/Asset Base URL
NEXT_PUBLIC_IMAGE_BASE_URL=https://rumi-test-backend-bucket.s3.eu-central-1.amazonaws.com
